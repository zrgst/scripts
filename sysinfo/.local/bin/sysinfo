#!/bin/bash

# Et scipt som kjĂ¸res via dmenu for ĂĄ vise systemstatus. Laget dette for ĂĄ slippe ĂĄ krangle med 'slstatus' pĂĄ dwm.
# Det blir mer ryddig ĂĄ hente denne informasjonen fra dmenu nĂĄr jeg trenger den enn ĂĄ bruke systemressurser pĂĄ ĂĄ
# alltid ha oppdatert informasjon i info-baren.

# Hent info
VOLUME=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100 "%"}')
MUSIC=$(mpc current || echo "Ingen musikk spiller...")
UPTIME=$(uptime -p | sed 's/up //')
MEMORY=$(free -h | awk '/^Mem:/ {print "îż… RAM:  " $3 " / " $2} /^Swap:/ {print "ó°Ť› Swap: " $3 " / " $2}')
CPUTEMP=$(sensors | grep 'Tctl' | awk '{print $2}' | tr -d '+')
KERNEL=$(uname -r)
GPU_DATA=$(nvidia-smi --query-gpu=temperature.gpu,memory.used,utilization.gpu --format=csv,noheader,nounits)
G_TEMP=$(echo $GPU_DATA | cut -d',' -f1 | xargs)
G_VRAM=$(echo $GPU_DATA | cut -d',' -f2 | xargs)
G_UTIL=$(echo $GPU_DATA | cut -d',' -f3 | xargs)


# Send informasjonen til 'dunst' for ĂĄ vise den pĂĄ skjermen. Jeg har en egen 'kategori' for dette som heter 'info'
# Den viser i 10 sekunder pĂĄ skjermen og er gul/orange. Kan ogsĂĄ fjerne '-c "info"' og legge inn
# '-u low -t 5000' for ĂĄ fĂĄ litt mer anonyme farger. FĂ¸lger da standard fargeskjema i dunst.
notify-send -c "info" "ó°Ł‡ System Status" \
"\nó°¤˝ Media:
ó°‹„ $MUSIC
ď€¨ Volum: $VOLUME\n
î­‘ System Information:
îś’ Kernel: $KERNEL
ó±Ž« Uptime: $UPTIME
${MEMORY}
ď‹‹ CPU-temp:$CPUTEMP
ó°»‘ GPU: ${G_TEMP}Â°C | ${G_VRAM}MB | ${G_UTIL}% "
