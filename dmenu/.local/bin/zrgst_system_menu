#!/bin/bash

# Definerer dmenu-innstillinger (for ГҘ matche dwm-look)
DMENU="dmenu -i -l 10 -p"

# ---------- Webapp meny ----------
webapp_menu() {
    webapp_valg=$(echo -e "у°ӘҒ Gemini\nу°Ҡ« Gmail\nпүҙ Kalender" | $DMENU "Webapps:" )
    case "$webapp_valg" in
        "у°ӘҒ Gemini")
            notify-send -c "info" "Gemini Webapp" "Г…pner Gemini Webapp..."
            ai_agent
            ;;
        "у°Ҡ« Gmail")
            notify-send -c "info" "Gmail" "Du mГҘ lage den fГёrst!"
            gmail_webapp
            ;;
        "пүҙ Kalender")
            notify-send -c "info" "Google Calendar" "Du mГҘ lage den fГёrst!"
            gcal_webapp
            ;;
    esac
}

# ---------- System meny ----------
system_menu() {
	choice=$(echo -e "пғҮ Diskstatus\nоҝ… Minnebruk\nпҢҡ Kernel-versjon\nпӮЁ Tilbake" | $DMENU "System Info:")
	case "$choice" in
		"пғҮ Diskstatus")
			# Viser diskstatus i dmenu linje (endre til notification senere)
			notify-send -c "info" "Diskstatus" "$(df -h)"
            system_menu
			;;
		"оҝ… Minnebruk")
			# Viser RAM status
            #status=$(free -h | awk '/^Mem:/ {print "RAM:" $3 " av " $2}')
			status=$(free -h | awk '/^Mem:/ {print "RAM:  " $3 " / " $2} /^Swap:/ {print "Swap: " $3 " / " $2}')
			#notify-send -c "info" "Minnebruk:" "$(free -h)"
			notify-send -c "info" "Minnebruk:" "$status"
            system_menu
			;;
		"пҢҡ Kernel-versjon")
			notify-send -c "info" "Kernel:" "$(uname -r)"
            system_menu
			;;
		"пӮЁ Tilbake")
			exec "$0" # Starter scriptet pГҘ nytt.
			;;
    esac
}

# ---------- Gaming meny ----------
twow_menu() {
	choice=$(echo -e "у°і— Turtle Wow\nу°і— Turtle Wow - Mangohud" | $DMENU "Turtle Wow:" )
	case "$choice" in
		"у°і— Turtle Wow")
                	notify-send -c "info" "Turtle WoW" "Starter Turtle WoW!\nGГҘ til tag 8 for ГҘ spille."
			turtle-gm 
			;;
		"у°і— Turtle Wow - Mangohud")
                	notify-send -c "info" "Turtle WoW - HUD" "Starter Turtle WoW med Mangohud!\nGГҘ til tag 8 for ГҘ spille."
			turtle-gm-hud
			;;
	esac

}



# ---------- Gaming meny ----------
gaming_menu() {
        choice=$(echo -e "пҶ· Steam\nуұўҫ Heroic Games Launcher\nуұ“һ Star Citizen\nу°і— Turtle Wow\nу°Қі Minecraft\nп„ӣ Roblox\nу°җқ Pokemmo" | $DMENU "Games:" )
        case "$choice" in
            "пҶ· Steam")
                notify-send -c "info" "Steam" "Starter Steam!"
                steam
                ;;
            "уұўҫ Heroic Games Launcher")
                notify-send -c "info" "Starter Heroic Games Launcher!"
                heroic
                ;;
            "у°і— Turtle Wow")
                twow_menu
                ;;
            " уұ“һ Star Citizen")
                notify-send -c "info" "Star Citizen" "Du har ikke isntallert dette ennГҘ..."
                ;;
            "у°Қі Minecraft")
                notify-send -c "info" "Minecraft" "Launching Prism Launcher!"
                prismlauncher
                ;;
            "п„ӣ Roblox")
                notify-send -c "info" "Roblox" "Starter Sober, Roblox launcher for Linux"
                flatpak run org.vinegarhq.Sober
                ;;
            "у°җқ Pokemmo")
                notify-send -c "info" "Pokemmo" "Starter Pokemmo!!"
                pokemmo-launcher
                ;;
        esac
}

noisetorch_menu() {
    local options="1. Aktiver\n2. Deaktiver"
    local choice=$(echo -e "$options" | dmenu -p "Noise Cancellation:" -i)

    case "$choice" in
        "1. Aktiver")
            # Starter noisetorch i bakgrunnen (bruker -i for standard input)
            noisetorch -i && notify-send "NoiseTorch" "StГёyreduksjon er aktivert"
            ;;
        "2. Deaktiver")
            # Stopper og fjerner det virtuelle grensesnittet
            noisetorch -u && notify-send "NoiseTorch" "StГёyreduksjon er deaktivert"
            ;;
    esac
}


# ---------- Hovedmeny ----------
main_menu() {
    choice=$(echo -e "у°өҶ Applications\nуұҺ“ Games\nпүЁ Webapps\nоӯ‘ System Info\nоҜҠ Terminal\nуұЎ¬ Noise Cancelling" | $DMENU "Zrgst Launcher:")
    case "$choice" in
        "у°өҶ Applications")
            j4-dmenu-desktop ;;
        "уұҺ“ Games")
            gaming_menu ;;
        "пүЁ Webapps")
            webapp_menu ;;
        "оӯ‘ System Info")
            sysinfo ;;
        "оҜҠ Terminal")
            st -e ;;
	"уұЎ¬ Noise Cancelling")
	    noisetorch_menu ;;
    esac
}

main_menu
